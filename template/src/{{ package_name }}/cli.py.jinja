"""Command line interface for {{ project_name }}."""

import typer

from {{ package_name }} import __version__
from {{ package_name }}.logging import setup_logging
from {{ package_name }}.settings import settings

app = typer.Typer(
    help="{{ project_name }} CLI",
    add_completion=False,
)


@app.callback()
def main(ctx: typer.Context) -> None:
    """{{ project_name }} CLI."""
    if ctx.invoked_subcommand is not None:
        setup_logging()


@app.command()
def info() -> None:
    """Display project information."""
    typer.echo(f"{settings.app.app_name} v{__version__}")
    typer.echo(f"Environment: {settings.app.environment}")
    typer.echo(f"File Level: {settings.logging.file_level}")
    typer.echo(f"Console Level: {settings.logging.console_level}")


if __name__ == "__main__":
    app()
