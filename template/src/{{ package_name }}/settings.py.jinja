"""Application settings configuration using Pydantic."""

import os
from pathlib import Path
from typing import Literal

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict

LogLevel = Literal["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]


def _env_files() -> tuple[str, ...]:
    """Return env files to load: base .env, then environment-specific override."""
    env = os.getenv("APP__ENVIRONMENT") or os.getenv("ENVIRONMENT", "development")
    files: list[str] = [".env"]
    specific = f".env.{env}"
    if Path(specific).exists():
        files.append(specific)
    return tuple(files)


class AppSettings(BaseSettings):
    """Application settings group."""

    app_name: str = Field(default="{{ project_name }}", description="Application name")
    environment: str = Field(default="development", description="Environment name")


class LoggingSettings(BaseSettings):
    """Logging settings group."""

    file_level: LogLevel = Field(default="DEBUG", description="File log level")
    console_level: LogLevel = Field(default="INFO", description="Console log level")
    log_file: Path = Field(default=Path("logs/app.log"), description="Log file path")


class Settings(BaseSettings):
    """Application settings with __-delimited nested groups."""

    app: AppSettings = Field(default_factory=AppSettings)
    logging: LoggingSettings = Field(default_factory=LoggingSettings)

    model_config = SettingsConfigDict(
        env_file=_env_files(),
        env_file_encoding="utf-8",
        case_sensitive=False,
        extra="forbid",
        env_nested_delimiter="__",
    )


settings = Settings()
