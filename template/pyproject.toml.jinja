[project]
name = "{{ project_name }}"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
version = "0.1.0"
{% if license == "MIT" %}
license = "MIT"
license-files = ["LICENSE"]
{% elif license == "Apache" %}
license = "Apache-2.0"
license-files = ["LICENSE"]
{% elif license == "EULA" %}
license-files = ["LICENSE"]
{% endif %}
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
keywords = ["python"]
classifiers = [
    "Development Status :: 4 - Beta",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: {{ python_version }}",
    "Typing :: Typed",
]
dependencies = [
    "typer>=0.12.0",
    "structlog>=24.0.0",
    "pydantic>=2.7.0",
    "pydantic-settings>=2.2.0",
]

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=5.0.0",
    "ruff>=0.4.0",
    "ty>=0.0.28",
    "ipython>=8.20.0",
    "mdformat>=0.7.0",
]

[project.optional-dependencies]
docs = [
    "mkdocs>=1.6.0",
    "mkdocs-material>=9.5.0",
    "mkdocstrings[python]>=0.25.0",
]

[project.scripts]
{{ project_name }} = "{{ package_name }}.cli:app"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "--cov=src/{{ package_name }} --cov-report=term-missing"

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 88
src = ["src"]

[tool.ruff.lint]
select = [
    "E", "W", "F", "I", "B", "C4", "UP", "ARG", "PT", "TCH", "RUF",
    "PL",    # Pylint rules
    "SIM",   # flake8-simplify
    "RET",   # flake8-return
    "PTH",   # flake8-use-pathlib
    "D",     # pydocstyle — enforce Google-style docstrings
]
ignore = [
    "D100", "D104",  # Missing docstring in public module/package
    "D203",          # Conflicts with D211
    "D213",          # Conflicts with D212
    "PLR0913",       # Too many arguments (context-dependent)
]

[tool.ruff.lint.pylint]
max-args = 8
max-returns = 10

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]
